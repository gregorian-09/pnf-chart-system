<!-- C# binding project file. -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>10.0</LangVersion>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;1587</NoWarn>
    <SkipTestSupport Condition="'$(SkipTestSupport)' == ''">false</SkipTestSupport>
    <Version>0.1.2</Version>
    <PackageId>PnF.ChartSystem</PackageId>
    <Authors>Gregorian Rayne</Authors>
    <Description>Point and Figure Chart Library - C# bindings</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>See CHANGELOG.md for release history and migration notes.</PackageReleaseNotes>
    <PackageProjectUrl>https://github.com/gregorian-09/pnf-chart-system</PackageProjectUrl>
    <PackageTags>finance;trading;technical-analysis;point-figure;chart</PackageTags>
    <RepositoryUrl>https://github.com/gregorian-09/pnf-chart-system</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup Condition="'$(SkipTestSupport)' != 'true'">
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="xunit" Version="2.6.4" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.6">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup Condition="'$(SkipTestSupport)' == 'true'">
    <Compile Remove="ChartTests.cs" />
    <Compile Remove="IndicatorTests.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
    <None Include="..\..\build\bin\pnf.dll" Link="pnf_native.dll" CopyToOutputDirectory="PreserveNewest" Condition="'$(OS)' == 'Windows_NT' AND Exists('..\..\build\bin\pnf.dll')" />
    <None Include="..\..\build\lib\libpnf.so" Link="pnf_native.so" CopyToOutputDirectory="PreserveNewest" Condition="'$(OS)' != 'Windows_NT' AND Exists('..\..\build\lib\libpnf.so')" />
    <None Include="..\..\build\lib\libpnf.dylib" Link="pnf_native.dylib" CopyToOutputDirectory="PreserveNewest" Condition="'$(OS)' != 'Windows_NT' AND Exists('..\..\build\lib\libpnf.dylib')" />
    <None Include="..\..\build\bin\pnf.dll" Pack="true" PackagePath="runtimes/win-x64/native/pnf_native.dll" Condition="Exists('..\..\build\bin\pnf.dll')" />
    <None Include="..\..\build\lib\libpnf.so" Pack="true" PackagePath="runtimes/linux-x64/native/pnf_native.so" Condition="Exists('..\..\build\lib\libpnf.so')" />
    <None Include="..\..\build\lib\libpnf.dylib" Pack="true" PackagePath="runtimes/osx-x64/native/pnf_native.dylib" Condition="Exists('..\..\build\lib\libpnf.dylib')" />
  </ItemGroup>

</Project>
